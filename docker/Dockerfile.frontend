FROM ghcr.io/cirruslabs/flutter:stable AS builder

WORKDIR /app
COPY frontend/ .
RUN flutter pub get && flutter build web --dart-define=API_BASE_URL=

FROM nginx:alpine
COPY --from=builder /app/build/web /usr/share/nginx/html
# nginx:alpine entrypoint auto-runs envsubst on *.template files → /etc/nginx/conf.d/
COPY docker/nginx.conf /etc/nginx/templates/default.conf.template
